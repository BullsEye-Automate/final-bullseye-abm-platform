# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro

# Clay (Sprint 2 — búsqueda y scoring de contactos)
CLAY_API_KEY=
CLAY_WORKBOOK_ID=
CLAY_COMPANIES_TABLE_ID=
CLAY_CONTACTS_TABLE_ID=

# Lemlist (Sprint 4 — outreach)
LEMLIST_API_KEY=
LEMLIST_CAMPAIGN_ID=
# ID del usuario de Lemlist que envía (cuenta de LinkedIn / mailbox conectada).
# Requerido para responder desde /respuestas (Lemlist Inbox API). Si el equipo
# tiene un solo usuario la app lo resuelve sola vía GET /api/team; si hay
# varios, seteá este ID a mano.
LEMLIST_SEND_USER_ID=
# ID de la campaña "puente" de Lemlist — buzón de entrada para los contactos
# que el usuario manda desde Sales Navigator con la extensión de Lemlist. El
# módulo /sales-navigator jala los leads de acá. Debe ser una campaña SIN
# secuencia (o pausada) para que no empiece a mandar sola.
LEMLIST_STAGING_CAMPAIGN_ID=

# HubSpot (Sprint 4 — CRM)
HUBSPOT_PRIVATE_APP_TOKEN=

# Lusha (Sprint 3+ — fallback teléfonos)
LUSHA_API_KEY=

# App
APP_DEFAULT_REVIEWER_EMAIL=
